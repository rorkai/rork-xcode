               BlueprintName = "ActionsApp"
               ReferencedContainer = "container:ActionsApp.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
   <TestAction
      buildConfiguration = "Debug"
