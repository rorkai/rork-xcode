{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "sortImports": {
    "groups": ["builtin", "external", "internal", ["parent", "sibling", "index"], "type"]
  }
}
